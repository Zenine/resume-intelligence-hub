# Files in this repo that are NOT part of the installed skill.
# The skills CLI / installer should omit these when copying to the user's
# .agents/skills/ directory. If the CLI doesn't recognise .skillignore,
# this file still serves as declarative intent for future tooling and
# as documentation for maintainers.

# VitePress marketing site — landing page source, not consumed by agents
docs/

# CI automation scripts (GSC sitemap notify) — maintainer infrastructure
scripts/

# Translator / maintainer tooling — glossary, drift rules
i18n/

# Non-EN README files — GitHub repo display only. EN README.md is kept
# because some skill consumers read it as supplementary docs.
README.zh.md
README.ja.md
README.zh-TW.md
